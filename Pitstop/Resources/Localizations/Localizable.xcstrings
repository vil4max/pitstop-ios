    "detail.service.explanation" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The next visit shows required and optional work. Complete it when your odometer enters the service window."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Следующий визит показывает обязательные и дополнительные работы. Завершите его, когда пробег войдёт в окно ТО."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Наступний візит показує обов'язкові та додаткові роботи. Завершіть його, коли пробіг увійде у вікно ТО."
          }
        }
      }
    },
    "detail.serviceEstimate.explanation" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The date is estimated from your average monthly mileage. It helps you plan ahead of the km-based window."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дата рассчитана по среднему пробегу в месяц. Помогает спланировать визит заранее."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дату розраховано за середнім пробігом на місяць. Допомагає спланувати візит заздалегідь."
          }
        }
      }
    },
