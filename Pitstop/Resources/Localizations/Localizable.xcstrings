    "detail.insurance.explanation" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We remind you before your policy ends so you have time to renew OSAGO."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Напомним до окончания полиса, чтобы успеть продлить ОСАГО."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нагадаємо до закінчення поліса, щоб встигнути продовжити ОСЦПВ."
          }
        }
      }
    },
    "detail.maintenance.explanation" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Major milestones like 20k and 22k km include extra checks beyond regular oil service."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Крупные ТО на 20 и 22 тыс. km включают дополнительные работы сверх регулярной замены масла."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Великі ТО на 20 і 22 тис. km включають додаткові роботи понад регулярну заміну масла."
          }
        }
      }
    },
    "detail.maintenance.footnote" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Based on your maintenance plan"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "По плану обслуживания"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "За планом обслуговування"
          }
        }
      }
    },
    "detail.odometer.explanation" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accurate mileage keeps service and oil reminders on time. Update it on the 1st of each month."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Актуальный пробег помогает вовремя напоминать о ТО и масле. Обновляйте его 1-го числа каждого месяца."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Актуальний пробіг допомагає вчасно нагадувати про ТО та масло. Оновлюйте його 1-го числа кожного місяця."
          }
        }
      }
    },
    "detail.odometer.value" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld km now"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сейчас %lld km"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Зараз %lld km"
          }
        }
      }
    },
    "detail.oil.explanation" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We remind you when you approach the oil change window. Open service to see the full checklist."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Напомним, когда подойдёте к окну замены масла. В ТО — полный список работ."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нагадаємо, коли наблизитесь до вікна заміни масла. У ТО — повний список робіт."
          }
        }
      }
    },
    "detail.seasonal.explanation" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twice a year we remind you to switch tires and review mileage and oil interval before the season."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дважды в год напоминаем о переобувке и проверке пробега и интервала масла перед сезоном."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Двічі на рік нагадуємо про переобувку та перевірку пробігу й інтервалу масла перед сезоном."
          }
        }
      }
    },
    "detail.seasonal.value.summer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Summer tires in %lld days"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
